# Copy this file to .env for local debugging.

# dashscope: Bailian/DashScope compatible-mode API.
# local: a local OpenAI-compatible server such as vLLM.
# mock: deterministic smoke-test client, no network required.
MODEL_PROVIDER=dashscope

# Bailian/DashScope
DASHSCOPE_API_KEY=
MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen3.5-35b-a3b
MODEL_API_KEY_ENV=DASHSCOPE_API_KEY

# Local vLLM example. To switch later, set:
# MODEL_PROVIDER=local
# MODEL_BASE_URL=http://127.0.0.1:8000/v1
# MODEL_NAME=qwen3-8b
# MODEL_API_KEY=EMPTY
# MODEL_API_KEY_ENV=

MODEL_TIMEOUT=180
MODEL_STREAM=true
MODEL_ENABLE_THINKING=false
MODEL_TEMPERATURE=0.0
MODEL_MAX_TOKENS=1024

AGENT_MAX_TOOL_ITERATIONS=4
AGENT_MAX_CONSECUTIVE_TOOL_ERRORS=2
ENABLE_SEARCH_TOOLS=false
ENABLE_CODE_EXECUTION=false
DEERFLOW_HARNESS=

# Dataset paths are intentionally local-relative by default.
SIMPLEVQA_ROOT=./datasets/SimpleVQA
SIMPLEVQA_IMAGE_ROOT=./datasets/SimpleVQA/simpleVQA_datasets
SIMPLEVQA_ANNOTATION_FILE=./datasets/SimpleVQA/simpleVQA_final_modified.json
